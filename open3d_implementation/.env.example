# RunPod Serverless ComfyUI
# Copy to .env and fill locally. Never commit real values.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ComfyUI workflow/runtime
COMFYUI_WORKFLOW_PATH=
COMFYUI_DEFAULT_CHECKPOINT=v1-5-pruned-emaonly.safetensors
COMFYUI_TIMEOUT=180

# Existing pipeline keys go here as needed.
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
