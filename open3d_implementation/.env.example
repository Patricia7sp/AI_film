# RunPod Serverless ComfyUI
# Copy to .env and fill locally. Never commit real values.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_GPU_USD_PER_SECOND=0.00097
RUNPOD_NETWORK_VOLUME_ID=
RUNPOD_NETWORK_VOLUME_DATACENTER=EUR-IS-1

# ComfyUI workflow/runtime
IMAGE_GENERATION_PROVIDER=comfyui
# Keep sdxl active until the FLUX.2 assets and compatible worker pass the remote smoke.
COMFYUI_MODEL_FAMILY=sdxl
IMAGE_GENERATION_MAX_ATTEMPTS=3
IMAGE_SEMANTIC_MIN_SCORE=88
IMAGE_MIN_EDGE_SHARPNESS=24
COMFYUI_WORKFLOW_PATH=
COMFYUI_DEFAULT_CHECKPOINT=ai-film-semantic-juggernaut-xl.safetensors
COMFYUI_CHECKPOINT_COMIC_STORYBOOK=ai-film-semantic-juggernaut-xl.safetensors
COMFYUI_CHECKPOINT_CINEMATIC_REALISM=ai-film-cinematic-realism.safetensors
COMFYUI_FLUX2_DIFFUSION_MODEL=flux-2-klein-base-4b.safetensors
COMFYUI_FLUX2_TEXT_ENCODER=qwen_3_4b.safetensors
COMFYUI_FLUX2_VAE=flux2-vae.safetensors
COMFYUI_FLUX2_STEPS=20
COMFYUI_FLUX2_CFG=5.0
COMFYUI_CONTROLNET_CANNY_MODEL=controlnet-canny-sdxl-1.0.safetensors
COMFYUI_CONTROLNET_DEPTH_MODEL=controlnet-depth-sdxl-1.0.safetensors
COMFYUI_CONTROL_IMAGE_MODE=semantic_depth
COMFYUI_CONTROLNET_STRENGTH=0.78
COMFYUI_IPADAPTER_ENABLED=true
COMFYUI_IPADAPTER_WEIGHT=0.72
# Optional original/licensed style LoRA stored in models/loras on the Network Volume.
COMFYUI_STYLE_LORA_COMIC_STORYBOOK=
COMFYUI_STYLE_LORA_STRENGTH=0.65
COMFYUI_INPAINT_DENOISE=0.85
COMFYUI_REFINER_ENABLED=false
COMFYUI_REFINER_CHECKPOINT=ai-film-dreamshaper-xl-turbo-sfw.safetensors
COMFYUI_REFINER_SCALE=1.25
COMFYUI_REFINER_DENOISE=0.18
COMFYUI_REFINER_STEPS=6
COMFYUI_RUNPOD_MAX_WAIT_SECONDS=120
COMFYUI_TIMEOUT=180

# Existing pipeline keys go here as needed.
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# LLM model routing
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_FAST_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_QUALITY_MODEL=gemini-3-pro-image
GEMINI_IMAGE_USD_PER_IMAGE=0.12
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_FAST_MODEL=gpt-5.4-nano

# Cost/quota guardrails for local curation UI
AI_FILM_COST_WARN_USD=1.00
AI_FILM_COST_LIMIT_USD=2.00
AI_FILM_RUNPOD_COST_LIMIT_USD=0.75
AI_FILM_RUNWAY_COST_LIMIT_USD=1.50
AI_FILM_ELEVENLABS_CHAR_LIMIT_PER_RUN=1200
